class Solution {
public:
    int rows, cols;

    void dfs(vector<vector<char>>& board, int r, int c) {
        // out of bounds, or not an 'O' — nothing to mark
        if (r < 0 || r >= rows || c < 0 || c >= cols || board[r][c] != 'O')
            return;

        board[r][c] = '#';           // mark as safe (temporarily)
        dfs(board, r+1, c);          // explore all 4 directions
        dfs(board, r-1, c);
        dfs(board, r, c+1);
        dfs(board, r, c-1);
    }

    void solve(vector<vector<char>>& board) {
        rows = board.size();
        cols = board[0].size();

        // Phase 1: mark all border-connected O's as safe (#)
        for (int r = 0; r < rows; r++) {
            for (int c = 0; c < cols; c++) {
                bool onBorder = (r==0 || r==rows-1 || c==0 || c==cols-1);
                if (onBorder && board[r][c] == 'O')
                    dfs(board, r, c);
            }
        }

        // Phase 2 & 3: one pass does both
        for (int r = 0; r < rows; r++) {
            for (int c = 0; c < cols; c++) {
                if (board[r][c] == 'O')  board[r][c] = 'X'; // surrounded → capture
                else if (board[r][c] == '#') board[r][c] = 'O'; // safe → restore
            }
        }
    }
};
